generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model accounts {
  id           Int            @id @default(autoincrement())
  full_name    String         @db.VarChar(100)
  phone_number String         @db.VarChar(50)
  birth_date   DateTime?      @db.Date
  username     String         @unique(map: "username") @db.VarChar(50)
  password     String         @db.VarChar(255)
  email        String         @unique(map: "email") @db.VarChar(100)
  role_id      Int            @default(2)
  is_deleted   Boolean        @default(false)
  is_verified  Boolean        @default(false)
  created_at   DateTime?      @default(now()) @db.DateTime(0)
  updated_at   DateTime?      @default(now()) @updatedAt @db.DateTime(0)
  roles        roles          @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "accounts_roles_fkey")
  bookings     bookings[]
  reviews      reviews[]
  transactions transactions[]
  wishlist     wishlist[]

  @@index([role_id], map: "fk_1")
}

model bookings {
  id           Int            @id @default(autoincrement())
  customer_id  Int?
  tour_id      Int
  account_id   Int
  start_date   DateTime       @db.DateTime(0)
  end_date     DateTime       @db.DateTime(0)
  total_amount BigInt
  paid_amount  BigInt?        @default(0)
  status       String?        @default("pending") @db.VarChar(50)
  is_confirmed Boolean?       @default(false)
  is_deleted   Boolean?       @default(false)
  created_at   DateTime?      @default(now()) @db.DateTime(0)
  updated_at   DateTime?      @default(now()) @updatedAt @db.DateTime(0)
  accounts     accounts       @relation(fields: [account_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "bookings_accounts_fkey")
  customers    customers?     @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "bookings_customers_fkey")
  tours        tours          @relation(fields: [tour_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "bookings_tours_fkey")
  transactions transactions[]

  @@index([customer_id], map: "fk_1")
  @@index([tour_id], map: "fk_2")
  @@index([account_id], map: "fk_3")
}

model customers {
  id            Int        @id @default(autoincrement())
  full_name     String     @db.VarChar(100)
  identity_card String?    @db.VarChar(50)
  is_male       Boolean?   @default(true)
  phone_number  String     @db.VarChar(50)
  address       String?    @db.VarChar(255)
  birth_date    DateTime?  @db.Date
  email         String?    @db.VarChar(100)
  is_deleted    Boolean?   @default(false)
  created_at    DateTime?  @default(now()) @db.DateTime(0)
  updated_at    DateTime?  @default(now()) @updatedAt @db.DateTime(0)
  bookings      bookings[]
}

model images {
  id         Int         @id @default(autoincrement())
  image_url  String      @db.VarChar(500)
  sort_order Int?        @default(0)
  is_deleted Boolean?    @default(false)
  created_at DateTime?   @default(now()) @db.DateTime(0)
  updated_at DateTime?   @default(now()) @updatedAt @db.DateTime(0)
  provinces  provinces[]
}

model promotions {
  id             Int            @id @default(autoincrement())
  code           String         @unique(map: "code") @db.VarChar(50)
  discount_type  String?        @db.VarChar(50)
  discount_value BigInt
  min_amount     BigInt?        @default(0)
  used_count     Int?           @default(0)
  start_date     DateTime       @db.DateTime(0)
  end_date       DateTime       @db.DateTime(0)
  is_active      Boolean?       @default(true)
  description    String?        @db.Text
  created_at     DateTime?      @default(now()) @db.DateTime(0)
  updated_at     DateTime?      @default(now()) @updatedAt @db.DateTime(0)
  category_name  String?        @db.VarChar(100)
  transactions   transactions[]
}

model provinces {
  id            Int       @id @default(autoincrement())
  image_id      Int?
  province_code String    @unique(map: "province_code") @db.VarChar(50)
  province_name String    @db.VarChar(100)
  note          String?   @db.VarChar(100)
  is_deleted    Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.DateTime(0)
  updated_at    DateTime? @default(now()) @updatedAt @db.DateTime(0)
  images        images?   @relation(fields: [image_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "provinces_images_fkey")
  tours         tours[]

  @@index([image_id], map: "fk_1")
}

model reviews {
  id          Int       @id @default(autoincrement())
  tour_id     Int
  account_id  Int
  rating      Int?
  comment     String?   @db.Text
  is_deleted  Boolean?  @default(false)
  created_at  DateTime? @default(now()) @db.DateTime(0)
  updated_at  DateTime? @default(now()) @updatedAt @db.DateTime(0)
  admin_reply String?   @db.Text
  accounts    accounts  @relation(fields: [account_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "reviews_accounts_fkey")
  tours       tours     @relation(fields: [tour_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "reviews_tours_fkey")

  @@index([tour_id], map: "fk_1")
  @@index([account_id], map: "fk_2")
}

model roles {
  id          Int        @id @default(autoincrement())
  role_name   String     @unique(map: "role_name") @db.VarChar(50)
  description String?    @db.VarChar(200)
  permissions String?    @db.Text
  created_at  DateTime?  @default(now()) @db.DateTime(0)
  updated_at  DateTime?  @default(now()) @updatedAt @db.DateTime(0)
  accounts    accounts[]
}

model tour_categories {
  id            Int       @id @default(autoincrement())
  category_name String    @unique(map: "category_name") @db.VarChar(100)
  note          String?   @db.VarChar(100)
  is_deleted    Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.DateTime(0)
  updated_at    DateTime? @default(now()) @updatedAt @db.DateTime(0)
  tours         tours[]
}

model tours {
  id              Int              @id @default(autoincrement())
  title           String           @db.VarChar(255)
  province_id     Int?
  location_name   String?          @db.VarChar(100)
  price           BigInt
  category_id     Int?
  description     String?          @db.Text
  sub_title       String?          @db.VarChar(255)
  max_slots       Int?             @default(20)
  is_active       Boolean?         @default(true)
  is_deleted      Boolean?         @default(false)
  created_at      DateTime?        @default(now()) @db.DateTime(0)
  updated_at      DateTime?        @default(now()) @updatedAt @db.DateTime(0)
  bookings        bookings[]
  reviews         reviews[]
  tour_images     tour_images[]
  provinces       provinces?       @relation(fields: [province_id], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "tours_provinces_fkey")
  tour_categories tour_categories? @relation(fields: [category_id], references: [id], onUpdate: NoAction, map: "tours_tour_categories_fkey")
  wishlist        wishlist[]
  map_url       String?  @db.Text

  @@index([category_id], map: "fk_1")
  @@index([province_id], map: "fk_2")
}

model transactions {
  id               Int         @id @default(autoincrement())
  booking_id       Int
  account_id       Int
  promotion_id     Int?
  amount           BigInt?     @default(0)
  transaction_type String?     @default("payment") @db.VarChar(50)
  created_at       DateTime?   @default(now()) @db.DateTime(0)
  accounts         accounts    @relation(fields: [account_id], references: [id], onUpdate: NoAction, map: "transactions_accounts_fkey")
  bookings         bookings    @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "transactions_bookings_fkey")
  promotions       promotions? @relation(fields: [promotion_id], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "transactions_promotions_fkey")

  @@index([booking_id], map: "fk_1")
  @@index([account_id], map: "fk_2")
  @@index([promotion_id], map: "fk_3")
}

model tour_images {
  id         Int       @id @default(autoincrement())
  tour_id    Int
  image_url  String    @db.VarChar(500)
  is_primary Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.DateTime(0)
  updated_at DateTime? @default(now()) @db.DateTime(0)
  tours      tours     @relation(fields: [tour_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tour_images_tours_fkey")

  @@index([tour_id], map: "fk_1")
}

model wishlist {
  id         Int       @id @default(autoincrement())
  account_id Int
  tour_id    Int
  created_at DateTime? @default(now()) @db.DateTime(0)
  accounts   accounts  @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "wishlist_accounts_fkey")
  tours      tours     @relation(fields: [tour_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "wishlist_tours_fkey")

  @@index([account_id], map: "fk_1")
  @@index([tour_id], map: "fk_2")
}

model districts {
  id            Int       @id @default(autoincrement())
  province_id   Int
  district_code String?   @db.VarChar(20)
  district_name String    @db.VarChar(100)
  is_deleted    Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.DateTime(0)
  updated_at    DateTime? @default(now()) @updatedAt @db.DateTime(0)

  @@index([province_id], map: "fk_1")
  @@index([province_id], map: "idx_districts_province")
}

model wards {
  id          Int       @id @default(autoincrement())
  district_id Int
  ward_code   String?   @db.VarChar(20)
  ward_name   String    @db.VarChar(100)
  is_deleted  Boolean?  @default(false)
  created_at  DateTime? @default(now()) @db.DateTime(0)
  updated_at  DateTime? @default(now()) @db.DateTime(0)

  @@index([district_id], map: "fk_1")
  @@index([district_id], map: "idx_wards_district")
}

model posts {
  id         Int      @id @default(autoincrement())
  title      String   @db.VarChar(255)
  excerpt    String?  @db.Text
  content    String   @db.Text
  category   String?  @db.VarChar(100)
  image_url  String?  @db.VarChar(500)
  views      Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @updatedAt @db.DateTime(0)
}
